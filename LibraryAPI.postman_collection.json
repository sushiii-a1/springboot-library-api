{
  "info": {
    "name": "Library API",
    "description": "REST API collection for Library Management System built with Spring Boot",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Books",
      "item": [
        {
          "name": "Get All Books",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8080/api/books",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "books"]
            }
          }
        },
        {
          "name": "Get Book By ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8080/api/books/1",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "books", "1"]
            }
          }
        },
        {
          "name": "Search Books By Title",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8080/api/books/search?title=harry",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "books", "search"],
              "query": [{ "key": "title", "value": "harry" }]
            }
          }
        },
        {
          "name": "Search Books By Author",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8080/api/books/search?author=rowling",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "books", "search"],
              "query": [{ "key": "author", "value": "rowling" }]
            }
          }
        },
        {
          "name": "Search Books By Genre",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8080/api/books/search?genre=fantasy",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "books", "search"],
              "query": [{ "key": "genre", "value": "fantasy" }]
            }
          }
        },
        {
          "name": "Add Book",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"title\": \"Harry Potter\",\n    \"author\": \"J.K. Rowling\",\n    \"genre\": \"Fantasy\",\n    \"available\": true\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/books",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "books"]
            }
          }
        },
        {
          "name": "Update Book",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"title\": \"Harry Potter Updated\",\n    \"author\": \"J.K. Rowling\",\n    \"genre\": \"Fantasy\",\n    \"available\": true\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/books/1",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "books", "1"]
            }
          }
        },
        {
          "name": "Delete Book",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "http://localhost:8080/api/books/1",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "books", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "Students",
      "item": [
        {
          "name": "Get All Students",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8080/api/students",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "students"]
            }
          }
        },
        {
          "name": "Get Student By ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8080/api/students/1",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "students", "1"]
            }
          }
        },
        {
          "name": "Add Student",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"John Doe\",\n    \"email\": \"john@example.com\",\n    \"phone\": \"9876543210\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/students",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "students"]
            }
          }
        },
        {
          "name": "Update Student",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"name\": \"John Doe Updated\",\n    \"email\": \"john.updated@example.com\",\n    \"phone\": \"9876543210\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/students/1",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "students", "1"]
            }
          }
        },
        {
          "name": "Delete Student",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "http://localhost:8080/api/students/1",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "students", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "Borrow & Return",
      "item": [
        {
          "name": "Borrow a Book",
          "request": {
            "method": "POST",
            "url": {
              "raw": "http://localhost:8080/api/borrow?bookId=1&studentId=1",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "borrow"],
              "query": [
                { "key": "bookId", "value": "1" },
                { "key": "studentId", "value": "1" }
              ]
            }
          }
        },
        {
          "name": "Return a Book",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "http://localhost:8080/api/borrow/return/1",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "borrow", "return", "1"]
            }
          }
        },
        {
          "name": "Get Student Borrow History",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:8080/api/borrow/student/1",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "borrow", "student", "1"]
            }
          }
        }
      ]
    }
  ]
}
